API_KEY=change-me-agent
PROVIDER_TYPE=wireguard

# Marzban settings (required if PROVIDER_TYPE=marzban)
# MARZBAN_URL=http://your-marzban-url
# MARZBAN_USERNAME=admin
# MARZBAN_PASSWORD=password

# AmneziaWG settings
# AWG_CONFIG_PATH=/etc/amnezia/amneziawg/wg0.conf

# WireGuard settings
# WG_CONFIG_PATH=/etc/wireguard/wg0.conf
