AGENT_API_KEY={{ agent_api_key }}
AGENT_PROVIDER_TYPE={{ kosatka_provider_type | default('awg') }}

# AmneziaWG / WireGuard — pydantic-settings reads AGENT_*-prefixed keys.
AGENT_AWG_CONFIG_PATH=/etc/amnezia/amneziawg/wg0.conf
AGENT_AWG_INTERFACE=wg0
AGENT_AWG_SERVER_INFO_PATH=/opt/kosatka/agent/awg_server.json
AGENT_WG_CONFIG_PATH=/etc/wireguard/wg0.conf
AGENT_WG_INTERFACE=wg0
AGENT_WG_SERVER_INFO_PATH=/opt/kosatka/agent/wg_server.json

# Marzban (only used when provider_type=marzban)
AGENT_MARZBAN_URL={{ marzban_url | default('http://127.0.0.1:8000') }}
AGENT_MARZBAN_USERNAME={{ marzban_username | default('') }}
AGENT_MARZBAN_PASSWORD={{ marzban_password | default('') }}
