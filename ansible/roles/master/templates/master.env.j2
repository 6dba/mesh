KOSATKA_API_KEY={{ kosatka_api_key }}
# Key master uses when calling agents. Must match AGENT_API_KEY in agent.env.
KOSATKA_AGENT_API_KEY={{ agent_api_key | default(kosatka_api_key) }}
KOSATKA_WEBHOOK_SECRET={{ kosatka_webhook_secret | default(kosatka_api_key) }}
KOSATKA_DATABASE_URL={{ kosatka_database_url }}
KOSATKA_SYNC_INTERVAL={{ kosatka_sync_interval | default(60) }}
KOSATKA_EXPIRATION_CHECK_INTERVAL={{ kosatka_expiration_check_interval | default(300) }}
