# KOSATKA Mesh Global Configuration

# Master Configuration
KOSATKA_API_KEY=your-secret-api-key-here
KOSATKA_DATABASE_URL=sqlite+aiosqlite:///./data/kosatka.db
KOSATKA_WEBHOOK_SECRET=your-webhook-secret-here

# Agent Configuration (for nodes)
KOSATKA_MASTER_URL=https://master.example.com
KOSATKA_NODE_ID=node-1

# Deployment
ANSIBLE_HOST_KEY_CHECKING=False
